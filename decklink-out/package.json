{
  "name": "decklink-out",
  "version": "1.0.0",
  "description": "Broadcast-graphics DeckLink SDI output — 1080p50 Fill+Key",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build-addon": "cd addon && ../node_modules/.bin/node-gyp rebuild --arch=x64 --target=28.3.3 --dist-url=https://electronjs.org/headers",
    "build-channeld": "cd channeld && ./build.sh",
    "build-playoutd": "cd playoutd && chmod +x build.sh && ./build.sh"
  },
  "dependencies": {
    "node-addon-api": "^7.1.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "node-gyp":  "^10.0.0"
  }
}
